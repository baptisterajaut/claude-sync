#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
CONFIG_DIR="${CLAUDE_SYNC_CONFIG_DIR:-$HOME/.config/claude-sync}"
CONFIG_FILE="$CONFIG_DIR/config"
LOCK_FILE="$CONFIG_DIR/.lock"
LAST_SYNC_DIR="$CONFIG_DIR/last-sync"
BACKUP_DIR="$CONFIG_DIR/backups"

DEFAULT_SYNCLIST="CLAUDE.md
settings.json
skills/
agents/"

EXCLUDE_PATTERNS="skills/claude-sync/"

DRY_RUN=false

usage() {
    cat <<EOF
claude-sync $VERSION — sync Claude Code config across machines

Usage: claude-sync <command> [options]

Commands:
    sync      Bidirectional safe sync with conflict detection
    status    Show per-file sync status
    diff      Show diff between local and remote
    update    Self-update from git repo
    init      First-time setup (install + launch Claude for config)
    fix       Launch Claude to resolve sync conflicts
    resolve [files...]  Accept local version for conflicting files (local → remote + base)

Options:
    -n, --dry-run   Preview actions without applying (sync)
    -h, --help      Show this help
    -v, --version   Show version
EOF
}

load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo "error: not configured (no config at $CONFIG_FILE)" >&2
        exit 1
    fi
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
    : "${REMOTE_PATH:?REMOTE_PATH not set in $CONFIG_FILE}"
    : "${CLAUDE_DIR:?CLAUDE_DIR not set in $CONFIG_FILE}"
    # Expand ~ in local paths (tilde isn't expanded when quoted in config files)
    CLAUDE_DIR="${CLAUDE_DIR/#\~/$HOME}"
    # REMOTE_PATH should always be absolute (resolved by /claude-sync:init)
}

load_synclist() {
    local synclist_file="$CONFIG_DIR/synclist"
    if [[ -f "$synclist_file" ]]; then
        grep -v '^#' "$synclist_file" | grep -v '^$'
    else
        echo "$DEFAULT_SYNCLIST"
    fi
}

# --- Notifications ---

notify() {
    local msg="$1"
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "claude-sync" "$msg" || true
    elif command -v osascript >/dev/null 2>&1; then
        osascript -e "display notification \"$msg\" with title \"claude-sync\"" || true
    elif command -v powershell.exe >/dev/null 2>&1; then
        powershell.exe -Command "New-BurntToastNotification -Text 'claude-sync','$msg'" 2>/dev/null || true
    fi
}

# --- Locking ---

acquire_local_lock() {
    if [[ -f "$LOCK_FILE" ]]; then
        read -r existing_pid _ < "$LOCK_FILE"
        if kill -0 "$existing_pid" 2>/dev/null; then
            echo "error: claude-sync already running (PID $existing_pid)" >&2
            return 1
        fi
        echo "warning: reclaiming stale lock from PID $existing_pid" >&2
        rm -f "$LOCK_FILE"
    fi
    echo "$$ $(date +%s)" > "$LOCK_FILE"
    trap release_local_lock EXIT
}

release_local_lock() {
    rm -f "$LOCK_FILE"
}

# Remote lock is handled by remote_init() and remote_finalize().
# release_remote_lock() is only for error cleanup paths.
release_remote_lock() {
    if [[ -z "${REMOTE_HOST:-}" ]]; then
        rm -f "$REMOTE_PATH/.claude-sync.lock"
    else
        ssh "$REMOTE_HOST" "rm -f \"$REMOTE_PATH/.claude-sync.lock\""
    fi
}

# --- File enumeration ---

enumerate_files() {
    local root_dir="$1"
    local synclist="$2"

    while IFS= read -r entry; do
        [[ -z "$entry" ]] && continue
        local full_path="$root_dir/$entry"
        if [[ "$entry" == */ ]]; then
            if [[ -d "$full_path" ]]; then
                (cd "$root_dir" && find "$entry" -type f 2>/dev/null) | while IFS= read -r f; do
                    if ! is_excluded "$f"; then
                        echo "$f"
                    fi
                done
            fi
        else
            if [[ -f "$full_path" ]] && ! is_excluded "$entry"; then
                echo "$entry"
            fi
        fi
    done <<< "$synclist"
}

is_excluded() {
    local path="$1"
    local pattern
    while IFS= read -r pattern; do
        [[ -z "$pattern" ]] && continue
        if [[ "$path" == "$pattern"* ]]; then
            return 0
        fi
    done <<< "$EXCLUDE_PATTERNS"
    return 1
}

# --- Checksums ---

compute_local_checksums() {
    local root_dir="$1"
    shift
    local files="$*"

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        if [[ -f "$root_dir/$filepath" ]]; then
            local hash
            hash=$(md5sum "$root_dir/$filepath" | awk '{print $1}')
            echo "$hash $filepath"
        else
            echo "ABSENT $filepath"
        fi
    done <<< "$files"
}

REMOTE_CHECKSUMS_CACHE=""

fetch_remote_checksums_readonly() {
    if [[ -z "${REMOTE_HOST:-}" ]]; then
        REMOTE_CHECKSUMS_CACHE=$(cd "$REMOTE_PATH" 2>/dev/null && find . -type f -not -name ".claude-sync.lock" -exec md5sum {} + 2>/dev/null | sed 's| \./| |' || true)
    else
        REMOTE_CHECKSUMS_CACHE=$(ssh "$REMOTE_HOST" "cd \"$REMOTE_PATH\" 2>/dev/null && find . -type f -not -name \".claude-sync.lock\" -exec md5sum {} + 2>/dev/null | sed 's| \./| |'" || true)
    fi
}

get_remote_checksum() {
    local filepath="$1"
    local line
    line=$(echo "$REMOTE_CHECKSUMS_CACHE" | grep -F " $filepath" | head -1)
    if [[ -n "$line" ]]; then
        echo "$line"
    else
        echo "ABSENT $filepath"
    fi
}

# --- Three-way comparison ---

decide_action() {
    local local_hash="$1" base_hash="$2" remote_hash="$3"

    if [[ "$local_hash" == "ABSENT" && "$base_hash" == "ABSENT" && "$remote_hash" == "ABSENT" ]]; then
        echo "clean"; return
    fi

    if [[ "$base_hash" == "ABSENT" ]]; then
        if [[ "$local_hash" != "ABSENT" && "$remote_hash" == "ABSENT" ]]; then
            echo "push-new"
        elif [[ "$local_hash" == "ABSENT" && "$remote_hash" != "ABSENT" ]]; then
            echo "pull-new"
        elif [[ "$local_hash" == "$remote_hash" ]]; then
            echo "create-base"
        else
            echo "conflict"
        fi
        return
    fi

    local local_changed=false remote_changed=false
    [[ "$local_hash" != "$base_hash" ]] && local_changed=true
    [[ "$remote_hash" != "$base_hash" ]] && remote_changed=true

    if ! $local_changed && ! $remote_changed; then
        echo "clean"
    elif $local_changed && ! $remote_changed; then
        if [[ "$local_hash" == "ABSENT" ]]; then echo "delete-remote"; else echo "push"; fi
    elif ! $local_changed && $remote_changed; then
        if [[ "$remote_hash" == "ABSENT" ]]; then echo "delete-local"; else echo "pull"; fi
    else
        if [[ "$local_hash" == "ABSENT" && "$remote_hash" == "ABSENT" ]]; then
            echo "delete-base"
        elif [[ "$local_hash" == "$remote_hash" ]]; then
            echo "update-base"
        else
            echo "conflict"
        fi
    fi
}

# --- Status command ---

action_label() {
    case "$1" in
        clean)          echo "clean" ;;
        push)           echo "local→" ;;
        push-new)       echo "new-local" ;;
        pull)           echo "←remote" ;;
        pull-new)       echo "new-remote" ;;
        update-base|create-base) echo "clean" ;;
        delete-remote)  echo "local→(del)" ;;
        delete-local)   echo "←remote(del)" ;;
        delete-base)    echo "clean" ;;
        conflict)       echo "CONFLICT" ;;
    esac
}

build_file_union() {
    local synclist="$1"
    {
        enumerate_files "$CLAUDE_DIR" "$synclist"
        enumerate_files "$LAST_SYNC_DIR" "$synclist"
        if [[ -z "${REMOTE_HOST:-}" ]]; then
            enumerate_files "$REMOTE_PATH" "$synclist"
        else
            ssh "$REMOTE_HOST" "cd \"$REMOTE_PATH\" 2>/dev/null && find . -type f 2>/dev/null | sed 's|^\./||'" | while IFS= read -r f; do
                if ! is_excluded "$f"; then
                    while IFS= read -r entry; do
                        [[ -z "$entry" ]] && continue
                        if [[ "$entry" == */ && "$f" == "$entry"* ]] || [[ "$f" == "$entry" ]]; then
                            echo "$f"
                            break
                        fi
                    done <<< "$synclist"
                fi
            done
        fi
    } | sort -u
}

cmd_status() {
    fetch_remote_checksums_readonly
    local synclist
    synclist=$(load_synclist)
    local all_files
    all_files=$(build_file_union "$synclist")

    if [[ -z "$all_files" ]]; then
        echo "No files to sync."
        return 0
    fi

    local has_conflict=false
    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        local local_hash base_hash remote_hash
        local_hash=$(compute_local_checksums "$CLAUDE_DIR" "$filepath" | awk '{print $1}')
        base_hash=$(compute_local_checksums "$LAST_SYNC_DIR" "$filepath" | awk '{print $1}')
        remote_hash=$(get_remote_checksum "$filepath" | awk '{print $1}')

        local action
        action=$(decide_action "$local_hash" "$base_hash" "$remote_hash")
        local label
        label=$(action_label "$action")

        printf "%-15s %s\n" "$label" "$filepath"
        [[ "$action" == "conflict" ]] && has_conflict=true
    done <<< "$all_files"

    # Check plugins.list status (not in synclist, managed separately)
    generate_plugins_list
    local local_plugins="" remote_plugins="" base_plugins=""
    [[ -f "$CLAUDE_DIR/plugins.list" ]] && local_plugins=$(sort -u "$CLAUDE_DIR/plugins.list")
    [[ -f "$LAST_SYNC_DIR/plugins.list" ]] && base_plugins=$(sort -u "$LAST_SYNC_DIR/plugins.list")
    # Get remote plugins.list checksum from cache
    local remote_pl_hash
    remote_pl_hash=$(get_remote_checksum "plugins.list" | awk '{print $1}')
    if [[ "$remote_pl_hash" != "ABSENT" ]]; then
        # Fetch the file content for comparison
        if [[ -z "${REMOTE_HOST:-}" ]]; then
            [[ -f "$REMOTE_PATH/plugins.list" ]] && remote_plugins=$(sort -u "$REMOTE_PATH/plugins.list")
        else
            remote_plugins=$(ssh "$REMOTE_HOST" "sort -u \"$REMOTE_PATH/plugins.list\" 2>/dev/null" || true)
        fi
    fi

    if [[ -n "$local_plugins" || -n "$remote_plugins" ]]; then
        if [[ "$local_plugins" == "$remote_plugins" ]]; then
            printf "%-15s %s\n" "clean" "plugins.list"
        elif [[ -z "$remote_plugins" ]]; then
            printf "%-15s %s\n" "new-local" "plugins.list"
        elif [[ -z "$local_plugins" ]]; then
            printf "%-15s %s\n" "new-remote" "plugins.list"
        else
            # Check if remote removed something
            if [[ -n "$base_plugins" ]]; then
                local removed
                removed=$(comm -23 <(echo "$base_plugins") <(echo "$remote_plugins") | comm -12 - <(echo "$local_plugins"))
                if [[ -n "$removed" ]]; then
                    printf "%-15s %s\n" "CONFLICT" "plugins.list"
                    has_conflict=true
                else
                    printf "%-15s %s\n" "mergeable" "plugins.list"
                fi
            else
                printf "%-15s %s\n" "mergeable" "plugins.list"
            fi
        fi
    fi

    if $has_conflict; then
        echo ""
        echo "Run 'claude-sync fix' to resolve conflicts." >&2
    fi
}

# --- Batch file transfers ---

batch_push() {
    local files_from="$1"
    if [[ -z "${REMOTE_HOST:-}" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            mkdir -p "$(dirname "$REMOTE_PATH/$f")"
            cp "$CLAUDE_DIR/$f" "$REMOTE_PATH/$f"
        done < "$files_from"
    else
        rsync -a --files-from="$files_from" "$CLAUDE_DIR/" "$REMOTE_HOST:$REMOTE_PATH/"
    fi
}

batch_pull() {
    local files_from="$1"
    if [[ -z "${REMOTE_HOST:-}" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            mkdir -p "$(dirname "$CLAUDE_DIR/$f")"
            cp "$REMOTE_PATH/$f" "$CLAUDE_DIR/$f"
        done < "$files_from"
    else
        rsync -a --files-from="$files_from" "$REMOTE_HOST:$REMOTE_PATH/" "$CLAUDE_DIR/"
    fi
}

batch_delete_remote() {
    local files="$1"
    if [[ -z "${REMOTE_HOST:-}" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            rm -f "$REMOTE_PATH/$f"
        done <<< "$files"
    else
        :  # handled by remote_finalize in SSH mode
    fi
}

batch_delete_local() {
    local files="$1"
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        rm -f "$CLAUDE_DIR/$f"
    done <<< "$files"
}

update_base_from_local() {
    local filepath="$1"
    mkdir -p "$(dirname "$LAST_SYNC_DIR/$filepath")"
    cp "$CLAUDE_DIR/$filepath" "$LAST_SYNC_DIR/$filepath"
}

remove_from_base() {
    local filepath="$1"
    rm -f "$LAST_SYNC_DIR/$filepath"
}

# --- Plugin list generation ---

# Generate plugins.list from installed_plugins.json before syncing.
# This creates a simple "name@marketplace" list that is machine-independent.
generate_plugins_list() {
    local installed="$CLAUDE_DIR/plugins/installed_plugins.json"
    local plugins_list="$CLAUDE_DIR/plugins.list"
    if [[ -f "$installed" ]]; then
        grep -oP '"[^"]+@[^"]+"' "$installed" | tr -d '"' | sort -u > "$plugins_list"
    fi
}

# Merge plugins.list: union if both sides only added, conflict if remote removed something.
# Returns: "clean", "merged", or "conflict"
merge_plugins_list() {
    local local_file="$CLAUDE_DIR/plugins.list"
    local base_file="$LAST_SYNC_DIR/plugins.list"
    local remote_file="$1"  # path to remote plugins.list (from tmpdir or REMOTE_PATH)

    # If neither exists, nothing to do
    [[ ! -f "$local_file" && ! -f "$remote_file" ]] && echo "clean" && return

    local local_list="" base_list="" remote_list=""
    [[ -f "$local_file" ]] && local_list=$(sort -u "$local_file")
    [[ -f "$base_file" ]] && base_list=$(sort -u "$base_file")
    [[ -f "$remote_file" ]] && remote_list=$(sort -u "$remote_file")

    # If identical, clean
    if [[ "$local_list" == "$remote_list" ]]; then
        echo "clean"
        return
    fi

    # Check if remote removed plugins that local still has
    if [[ -n "$base_list" && -n "$remote_list" ]]; then
        local removed_from_remote
        removed_from_remote=$(comm -23 <(echo "$base_list") <(echo "$remote_list"))
        local still_in_local
        still_in_local=$(comm -12 <(echo "$removed_from_remote") <(echo "$local_list"))
        if [[ -n "$still_in_local" ]]; then
            echo "conflict"
            echo "Remote removed plugins still present locally:" >&2
            echo "$still_in_local" | sed 's/^/  /' >&2
            return
        fi
    fi

    # Safe to merge: union of both
    { echo "$local_list"; echo "$remote_list"; } | sort -u > "$local_file"
    echo "merged"
}

# --- Backups ---

create_local_backup() {
    mkdir -p "$BACKUP_DIR"
    local synclist
    synclist=$(load_synclist)
    local files
    files=$(enumerate_files "$CLAUDE_DIR" "$synclist")
    if [[ -n "$files" ]]; then
        local backup_file
        backup_file="$BACKUP_DIR/$(date -Iseconds).tar.gz"
        # shellcheck disable=SC2086
        tar -czf "$backup_file" -C "$CLAUDE_DIR" $files 2>/dev/null || true
    fi
}

prune_old_backups() {
    if [[ -d "$BACKUP_DIR" ]]; then
        find "$BACKUP_DIR" -maxdepth 1 -name "*.tar.gz" -mtime +30 -delete 2>/dev/null || true
    fi
}

# --- Remote combined operations ---

remote_init() {
    if [[ -z "${REMOTE_HOST:-}" ]]; then
        mkdir -p "$REMOTE_PATH"
        ( cd "$REMOTE_PATH" && find . -type f -not -name ".claude-sync.lock" -exec md5sum {} + 2>/dev/null | sed 's| \./| |' ) || true
    else
        ssh "$REMOTE_HOST" '
            set -e
            set -C
            echo "'"'$HOSTNAME'"'" > "'"$REMOTE_PATH"'/.claude-sync.lock" 2>/dev/null || {
                age=$(( $(date +%s) - $(stat -c %Y "'"$REMOTE_PATH"'/.claude-sync.lock" 2>/dev/null || echo 0) ))
                if [ "$age" -gt 300 ]; then
                    rm -f "'"$REMOTE_PATH"'/.claude-sync.lock"
                    echo "'"'$HOSTNAME'"'" > "'"$REMOTE_PATH"'/.claude-sync.lock"
                else
                    echo "LOCKED_BY $(cat "'"$REMOTE_PATH"'/.claude-sync.lock" 2>/dev/null)" >&2
                    exit 1
                fi
            }
            set +C
            mkdir -p "'"$REMOTE_PATH"'"
            cd "'"$REMOTE_PATH"'" && find . -type f -not -name ".claude-sync.lock" -exec md5sum {} + 2>/dev/null | sed "s| \./| |"
        '
    fi
}

remote_finalize() {
    local verify_file="$1"
    local delete_files="$2"
    if [[ -z "${REMOTE_HOST:-}" ]]; then
        if [[ -s "$verify_file" ]]; then
            while IFS= read -r f; do
                [[ -z "$f" ]] && continue
                md5sum "$REMOTE_PATH/$f" | sed "s|$REMOTE_PATH/||"
            done < "$verify_file"
        fi
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            rm -f "$REMOTE_PATH/$f"
        done <<< "$delete_files"
        rm -f "$REMOTE_PATH/.claude-sync.lock"
    else
        local script='cd "'"$REMOTE_PATH"'"; '
        if [[ -s "$verify_file" ]]; then
            while IFS= read -r f; do
                [[ -z "$f" ]] && continue
                script+="md5sum \"$f\"; "
            done < "$verify_file"
        fi
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            script+="rm -f \"$f\"; "
        done <<< "$delete_files"
        script+='rm -f .claude-sync.lock'
        ssh "$REMOTE_HOST" "$script"
    fi
}

# --- Sync command ---

cmd_sync() {
    acquire_local_lock

    # Phase 1: remote_init (lock + bootstrap + checksums)
    local remote_checksums
    if ! remote_checksums=$(remote_init); then
        echo "error: could not connect to remote (locked or unreachable)" >&2
        return 1
    fi
    REMOTE_CHECKSUMS_CACHE="$remote_checksums"
    trap 'release_remote_lock; release_local_lock' EXIT

    mkdir -p "$LAST_SYNC_DIR"

    # Generate plugins.list before comparing checksums
    generate_plugins_list

    local synclist all_files
    synclist=$(load_synclist)
    all_files=$(build_file_union "$synclist")

    if [[ -z "$all_files" ]]; then
        echo "No files to sync."
        release_remote_lock; trap release_local_lock EXIT
        return 0
    fi

    # Phase 2: Decide actions — build lists
    local push_list="" pull_list="" delete_remote_list="" delete_local_list=""
    local base_update_list="" base_remove_list="" conflict_list=""
    local tmpdir
    tmpdir=$(mktemp -d)

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        local local_hash base_hash remote_hash action
        local_hash=$(compute_local_checksums "$CLAUDE_DIR" "$filepath" | awk '{print $1}')
        base_hash=$(compute_local_checksums "$LAST_SYNC_DIR" "$filepath" | awk '{print $1}')
        remote_hash=$(get_remote_checksum "$filepath" | awk '{print $1}')
        action=$(decide_action "$local_hash" "$base_hash" "$remote_hash")

        case "$action" in
            clean) ;;
            push|push-new) push_list+="$filepath"$'\n'; base_update_list+="$filepath"$'\n' ;;
            pull|pull-new) pull_list+="$filepath"$'\n'; base_update_list+="$filepath"$'\n' ;;
            update-base|create-base) base_update_list+="$filepath"$'\n' ;;
            delete-remote) delete_remote_list+="$filepath"$'\n'; base_remove_list+="$filepath"$'\n' ;;
            delete-local) delete_local_list+="$filepath"$'\n'; base_remove_list+="$filepath"$'\n' ;;
            delete-base) base_remove_list+="$filepath"$'\n' ;;
            conflict) conflict_list+="$filepath"$'\n' ;;
        esac
    done <<< "$all_files"

    # Dry run: just print and exit
    if $DRY_RUN; then
        [[ -n "$push_list" ]] && echo "$push_list" | sed '/^$/d' | sed 's/^/[dry-run] push: /'
        [[ -n "$pull_list" ]] && echo "$pull_list" | sed '/^$/d' | sed 's/^/[dry-run] pull: /'
        [[ -n "$delete_remote_list" ]] && echo "$delete_remote_list" | sed '/^$/d' | sed 's/^/[dry-run] delete remote: /'
        [[ -n "$delete_local_list" ]] && echo "$delete_local_list" | sed '/^$/d' | sed 's/^/[dry-run] delete local: /'
        [[ -n "$conflict_list" ]] && echo "$conflict_list" | sed '/^$/d' | sed 's/^/CONFLICT: /' >&2
        release_remote_lock; trap release_local_lock EXIT; rm -rf "$tmpdir"
        [[ -n "$conflict_list" ]] && return 1
        [[ -z "$push_list$pull_list$delete_remote_list$delete_local_list" ]] && echo "Everything in sync."
        return 0
    fi

    # Phase 3: Backup before local modifications
    if [[ -n "$pull_list" || -n "$delete_local_list" ]]; then
        create_local_backup
    fi

    # Phase 4: Batch transfers
    if [[ -n "$push_list" ]]; then
        local push_file="$tmpdir/push_list"
        echo "$push_list" | sed '/^$/d' > "$push_file"
        batch_push "$push_file"
        echo "$push_list" | sed '/^$/d' | sed 's/^/pushed: /'
    fi
    if [[ -n "$pull_list" ]]; then
        local pull_file="$tmpdir/pull_list"
        echo "$pull_list" | sed '/^$/d' > "$pull_file"
        batch_pull "$pull_file"
        echo "$pull_list" | sed '/^$/d' | sed 's/^/pulled: /'
    fi
    if [[ -n "$delete_local_list" ]]; then
        batch_delete_local "$delete_local_list"
        echo "$delete_local_list" | sed '/^$/d' | sed 's/^/deleted local: /'
    fi

    # Phase 5: Verify + remote deletes + release lock
    local verify_file="$tmpdir/verify_list"
    echo "$push_list" | sed '/^$/d' > "$verify_file"
    local verify_output
    verify_output=$(remote_finalize "$verify_file" "$delete_remote_list")
    trap release_local_lock EXIT

    if [[ -n "$delete_remote_list" ]]; then
        echo "$delete_remote_list" | sed '/^$/d' | sed 's/^/deleted remote: /'
    fi

    # Verify push checksums
    if [[ -n "$push_list" ]]; then
        while IFS= read -r filepath; do
            [[ -z "$filepath" ]] && continue
            local expected actual
            expected=$(md5sum "$CLAUDE_DIR/$filepath" | awk '{print $1}')
            actual=$(echo "$verify_output" | grep -F "$filepath" | awk '{print $1}')
            if [[ "$expected" != "$actual" ]]; then
                echo "error: integrity check failed for $filepath (push)" >&2
            fi
        done <<< "$push_list"
    fi

    # Phase 6: Update base
    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        update_base_from_local "$filepath"
    done <<< "$base_update_list"
    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        remove_from_base "$filepath"
    done <<< "$base_remove_list"

    prune_old_backups

    local plugins_changed=false

    # Phase 8: Merge plugins.list (handled separately — additive merge, not three-way)
    generate_plugins_list
    local pre_merge_plugins=""
    [[ -f "$CLAUDE_DIR/plugins.list" ]] && pre_merge_plugins=$(cat "$CLAUDE_DIR/plugins.list")
    local remote_plugins_file
    if [[ -z "${REMOTE_HOST:-}" ]]; then
        remote_plugins_file="$REMOTE_PATH/plugins.list"
    else
        # Already fetched by remote_init, but plugins.list wasn't in the checksum
        # Fetch it now — single small file
        remote_plugins_file="$tmpdir/remote_plugins.list"
        if ! rsync -a "$REMOTE_HOST:$REMOTE_PATH/plugins.list" "$remote_plugins_file" 2>/dev/null; then
            remote_plugins_file=""  # doesn't exist on remote yet
        fi
    fi

    # Recreate tmpdir if it was cleaned up
    [[ -d "$tmpdir" ]] || tmpdir=$(mktemp -d)

    if [[ -n "$remote_plugins_file" && -f "$remote_plugins_file" ]]; then
        local merge_result
        merge_result=$(merge_plugins_list "$remote_plugins_file")
        case "$merge_result" in
            clean) ;;
            merged)
                # Push merged list to remote + update base
                if ! $DRY_RUN; then
                    if [[ -z "${REMOTE_HOST:-}" ]]; then
                        cp "$CLAUDE_DIR/plugins.list" "$REMOTE_PATH/plugins.list"
                    else
                        rsync -a "$CLAUDE_DIR/plugins.list" "$REMOTE_HOST:$REMOTE_PATH/plugins.list"
                    fi
                    mkdir -p "$LAST_SYNC_DIR"
                    cp "$CLAUDE_DIR/plugins.list" "$LAST_SYNC_DIR/plugins.list"
                    echo "plugins.list: merged"
                    # Show what's new
                    local new_plugins
                    new_plugins=$(comm -13 <(echo "$pre_merge_plugins" | sort) <(sort "$CLAUDE_DIR/plugins.list"))
                    if [[ -n "$new_plugins" ]]; then
                        echo "$new_plugins" | sed 's/^/  new: /'
                    fi
                    plugins_changed=true
                else
                    echo "[dry-run] plugins.list: would merge"
                fi
                ;;
            conflict)
                echo "CONFLICT: plugins.list (remote removed plugins still present locally)" >&2
                conflict_list+="plugins.list"$'\n'
                ;;
        esac
    elif [[ -f "$CLAUDE_DIR/plugins.list" ]]; then
        # Only local exists — push to remote
        if ! $DRY_RUN; then
            if [[ -z "${REMOTE_HOST:-}" ]]; then
                cp "$CLAUDE_DIR/plugins.list" "$REMOTE_PATH/plugins.list"
            else
                rsync -a "$CLAUDE_DIR/plugins.list" "$REMOTE_HOST:$REMOTE_PATH/plugins.list"
            fi
            mkdir -p "$LAST_SYNC_DIR"
            cp "$CLAUDE_DIR/plugins.list" "$LAST_SYNC_DIR/plugins.list"
            echo "pushed: plugins.list"
        else
            echo "[dry-run] push: plugins.list"
        fi
    fi

    rm -rf "$tmpdir" 2>/dev/null || true

    # Auto-install missing plugins if plugins.list changed
    if $plugins_changed && ! $DRY_RUN && command -v claude >/dev/null 2>&1; then
        echo "Installing missing plugins..." >&2
        while IFS= read -r plugin; do
            [[ -z "$plugin" ]] && continue
            claude plugin install "$plugin" --scope user 2>/dev/null && \
                echo "  installed: $plugin" || \
                echo "  skipped: $plugin" 2>/dev/null
        done < "$CLAUDE_DIR/plugins.list"
    fi

    # Report conflicts (from both normal sync and plugins merge)
    if [[ -n "$conflict_list" ]]; then
        echo "$conflict_list" | sed '/^$/d' | sed 's/^/CONFLICT: /' >&2
        notify "claude-sync: conflicts detected — run 'claude-sync fix'" 2>/dev/null || true
        echo "Conflicts detected. Run 'claude-sync fix' to resolve." >&2
        return 1
    fi

    if [[ -z "$push_list$pull_list$delete_remote_list$delete_local_list" ]] && ! $plugins_changed; then
        echo "Everything in sync."
    fi
}

# --- Diff command ---

cmd_diff() {
    fetch_remote_checksums_readonly
    local synclist all_files
    synclist=$(load_synclist)
    all_files=$(build_file_union "$synclist")

    if [[ -z "$all_files" ]]; then
        echo "No files to compare."
        return 0
    fi

    local changed_files=""
    declare -A file_actions
    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        local local_hash base_hash remote_hash action
        local_hash=$(compute_local_checksums "$CLAUDE_DIR" "$filepath" | awk '{print $1}')
        base_hash=$(compute_local_checksums "$LAST_SYNC_DIR" "$filepath" | awk '{print $1}')
        remote_hash=$(get_remote_checksum "$filepath" | awk '{print $1}')
        action=$(decide_action "$local_hash" "$base_hash" "$remote_hash")
        if [[ "$action" != "clean" ]]; then
            changed_files+="$filepath"$'\n'
            file_actions["$filepath"]="$action"
        fi
    done <<< "$all_files"

    if [[ -z "$changed_files" ]]; then
        echo "No differences found."
        return 0
    fi

    # Fetch remote versions of changed files to a temp dir
    local tmpdir
    tmpdir=$(mktemp -d)
    local fetch_list="$tmpdir/fetch_list"
    echo "$changed_files" | sed '/^$/d' > "$fetch_list"

    if [[ -z "${REMOTE_HOST:-}" ]]; then
        # Local mode: copy from REMOTE_PATH
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            if [[ -f "$REMOTE_PATH/$f" ]]; then
                mkdir -p "$(dirname "$tmpdir/remote/$f")"
                cp "$REMOTE_PATH/$f" "$tmpdir/remote/$f"
            fi
        done < "$fetch_list"
    else
        rsync -a --files-from="$fetch_list" "$REMOTE_HOST:$REMOTE_PATH/" "$tmpdir/remote/" 2>/dev/null || true
    fi

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        local action="${file_actions[$filepath]}"
        local local_file="$CLAUDE_DIR/$filepath"
        local remote_file="$tmpdir/remote/$filepath"

        local local_hash remote_hash
        local_hash=$(compute_local_checksums "$CLAUDE_DIR" "$filepath" | awk '{print $1}')
        remote_hash=$(get_remote_checksum "$filepath" | awk '{print $1}')

        echo "=== $filepath ($action) ==="
        if [[ "$local_hash" == "ABSENT" ]]; then
            echo "(local: absent, remote: exists)"
            cat "$remote_file" 2>/dev/null || true
        elif [[ "$remote_hash" == "ABSENT" ]]; then
            echo "(local: exists, remote: absent)"
            cat "$local_file"
        else
            diff -u --label "local/$filepath" "$local_file" --label "remote/$filepath" "$remote_file" || true
        fi
        echo ""
    done <<< "$changed_files"

    rm -rf "$tmpdir"
}

# --- Resolve command ---

# Accept local version as the resolved merge for conflicting files.
# Pushes local → remote and updates base. Only for files currently in conflict.
cmd_resolve() {
    local requested_files=("$@")

    acquire_local_lock
    local remote_checksums
    if ! remote_checksums=$(remote_init); then
        echo "error: could not connect to remote (locked or unreachable)" >&2
        return 1
    fi
    REMOTE_CHECKSUMS_CACHE="$remote_checksums"
    trap 'release_remote_lock; release_local_lock' EXIT

    mkdir -p "$LAST_SYNC_DIR"
    generate_plugins_list

    local synclist all_files
    synclist=$(load_synclist)
    all_files=$(build_file_union "$synclist")

    # Find files in conflict, filter by requested files if any
    local resolved_count=0
    local tmpdir
    tmpdir=$(mktemp -d)
    local push_file="$tmpdir/push_list"
    : > "$push_file"

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        local local_hash base_hash remote_hash action
        local_hash=$(compute_local_checksums "$CLAUDE_DIR" "$filepath" | awk '{print $1}')
        base_hash=$(compute_local_checksums "$LAST_SYNC_DIR" "$filepath" | awk '{print $1}')
        remote_hash=$(get_remote_checksum "$filepath" | awk '{print $1}')
        action=$(decide_action "$local_hash" "$base_hash" "$remote_hash")

        if [[ "$action" == "conflict" ]]; then
            # If specific files requested, only resolve those
            if (( ${#requested_files[@]} > 0 )); then
                local match=false
                for req in "${requested_files[@]}"; do
                    [[ "$filepath" == "$req" ]] && match=true && break
                done
                $match || continue
            fi
            echo "$filepath" >> "$push_file"
            (( resolved_count++ )) || true
        fi
    done <<< "$all_files"

    # Also handle plugins.list (not in synclist but resolvable)
    if [[ -f "$CLAUDE_DIR/plugins.list" ]]; then
        local should_resolve_plugins=false
        if (( ${#requested_files[@]} == 0 )); then
            should_resolve_plugins=true
        else
            for req in "${requested_files[@]}"; do
                [[ "$req" == "plugins.list" ]] && should_resolve_plugins=true && break
            done
        fi
        if $should_resolve_plugins; then
            local local_pl_hash remote_pl_hash
            local_pl_hash=$(md5sum "$CLAUDE_DIR/plugins.list" | awk '{print $1}')
            remote_pl_hash=$(get_remote_checksum "plugins.list" | awk '{print $1}')
            if [[ "$local_pl_hash" != "$remote_pl_hash" ]]; then
                echo "plugins.list" >> "$push_file"
                (( resolved_count++ )) || true
            fi
        fi
    fi

    if (( resolved_count == 0 )); then
        if (( ${#requested_files[@]} > 0 )); then
            echo "error: specified files are not in conflict" >&2
            rm -rf "$tmpdir"
            release_remote_lock
            trap release_local_lock EXIT
            return 1
        fi
        echo "No conflicts to resolve."
        rm -rf "$tmpdir"
        release_remote_lock
        trap release_local_lock EXIT
        return 0
    fi

    # Push local versions to remote
    batch_push "$push_file"

    # Verify + release lock
    local verify_output
    verify_output=$(remote_finalize "$push_file" "")
    trap release_local_lock EXIT

    # Update base from local
    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        update_base_from_local "$filepath"
        echo "resolved: $filepath (local → remote)"
    done < "$push_file"

    rm -rf "$tmpdir"
    echo "Resolved $resolved_count conflict(s). Run 'claude-sync sync' to verify."
}

# --- Update command ---

cmd_update() {
    # Find repo dir: follow symlink to the real script location
    local real_script
    real_script=$(readlink -f "${BASH_SOURCE[0]}")
    local repo_dir
    repo_dir=$(dirname "$real_script")

    if [[ ! -d "$repo_dir/.git" ]]; then
        echo "error: $repo_dir is not a git repo (script not installed via symlink?)" >&2
        exit 1
    fi

    echo "Pulling latest from $(git -C "$repo_dir" remote get-url origin)..."
    git -C "$repo_dir" pull

    # Reinstall plugin
    if command -v claude >/dev/null 2>&1; then
        claude plugin install --plugin-dir "$repo_dir" --scope user 2>/dev/null || true
    fi
    echo "Updated plugin and skills"

    echo "Update complete (v$(bash "$repo_dir/claude-sync" --version | awk '{print $2}'))."
}


# --- Init command (install + launch skill) ---

cmd_init() {
    local real_script
    real_script=$(readlink -f "${BASH_SOURCE[0]}")
    local repo_dir
    repo_dir=$(dirname "$real_script")

    # Symlink script into PATH (if not already)
    local target_dir="$HOME/.local/bin"
    mkdir -p "$target_dir"
    local target="$target_dir/claude-sync"
    if [[ -L "$target" || -f "$target" ]]; then
        local existing
        existing=$(readlink -f "$target" 2>/dev/null || echo "$target")
        if [[ "$existing" != "$repo_dir/claude-sync" ]]; then
            echo "warning: $target already exists (pointing to $existing)" >&2
            echo "Remove it first if you want to relink." >&2
        fi
    else
        ln -s "$repo_dir/claude-sync" "$target"
        echo "Linked: $target → $repo_dir/claude-sync"
    fi

    # Add to PATH for this session so claude-sync works inside Claude
    export PATH="$target_dir:$PATH"

    # Launch Claude with the plugin — the skill handles PATH persistence
    cmd_launch_skill "init"
}

# --- Launch Claude with a skill ---

cmd_launch_skill() {
    local skill_name="$1"
    local real_script
    real_script=$(readlink -f "${BASH_SOURCE[0]}")
    local repo_dir
    repo_dir=$(dirname "$real_script")

    if ! command -v claude >/dev/null 2>&1; then
        echo "error: claude CLI not found in PATH" >&2
        exit 1
    fi

    exec claude --plugin-dir "$repo_dir" \
        --append-system-prompt "When the user sends a message starting with /, invoke the corresponding skill immediately using the Skill tool. Do not explain what the skill does — just invoke it." \
        "/claude-sync:$skill_name"
}

# Allow sourcing for tests
if [[ "${1:-}" == "--source-only" ]]; then
    return 0 2>/dev/null || exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -n|--dry-run) DRY_RUN=true; shift ;;
        -h|--help) usage; exit 0 ;;
        -v|--version) echo "claude-sync $VERSION"; exit 0 ;;
        -*) echo "error: unknown option $1" >&2; exit 1 ;;
        *) break ;;
    esac
done

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    sync)   load_config; cmd_sync "$@" ;;
    status) load_config; cmd_status "$@" ;;
    diff)   load_config; cmd_diff "$@" ;;
    update)  load_config; cmd_update "$@" ;;
    init)    cmd_init "$@" ;;
    fix)     cmd_launch_skill "fix" ;;
    resolve) load_config; cmd_resolve "$@" ;;
    "")      usage; exit 1 ;;
    *)      echo "error: unknown command '$COMMAND'" >&2; exit 1 ;;
esac
